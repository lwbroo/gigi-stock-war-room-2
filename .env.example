# Copy this to .env and fill in your values
# Never commit .env — it contains secrets

GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

FINMIND_TOKEN=your_finmind_token_here

# Optional — only needed if you want simulate.py to notify cloud after push
# Leave blank to skip cloud reload (it auto-syncs within 1 hour)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
